{
	"name": "@savvy-web/dependency-package",
	"description": "Shared dependency package used by other packages in the workspace",
	"version": "0.5.0",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/workflow-integration.git",
		"directory": "pkgs/dependency"
	},
	"scripts": {
		"build:dev": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' rslib build --env-mode dev",
		"build:npm": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' rslib build --env-mode npm",
		"lint": "biome lint",
		"test": "vitest --run --root ../.. --config vitest.config.ts --project @savvy-web/dependency-package",
		"test:related": "vitest related --run --coverage=false --root ../.. --config vitest.config.ts --project @savvy-web/dependency-package",
		"typecheck": "tsgo --noEmit"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"devDependencies": {
		"@microsoft/api-extractor": "^7.55.1",
		"@rsbuild/core": "^1.6.9",
		"@rslib/core": "^0.18.2",
		"@savvy-web/builder": "workspace:*",
		"@types/node": "^24.10.1",
		"vitest": "^4.0.14"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"directory": "dist/npm",
				"access": "public",
				"registry": "https://registry.savvyweb.dev/"
			}
		]
	}
}
