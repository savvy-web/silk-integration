{
	"$schema": "https://turborepo.com/schema.v2.json",
	"globalPassThroughEnv": ["GITHUB_ACTIONS", "CI"],
	"tasks": {
		"//#types:check": {
			"cache": true,
			"dependsOn": [],
			"inputs": ["$TURBO_DEFAULT$", "!**/*.md", "!.changeset/**", "!.github/**"],
			"outputLogs": "errors-only",
			"outputs": []
		},
		"//#vitest:all": {
			"cache": false,
			"dependsOn": ["//#types:check"],
			"outputLogs": "full"
		}
	}
}
