name: Release

on:
  push:
    branches:
      - main
      - changeset-release/main
  workflow_dispatch:
    inputs:
      dry_run:
        description: Run in dry-run mode (preview only)
        required: true
        type: boolean
        default: true

concurrency:
  group: release-${{ github.ref }}
  cancel-in-progress: false

permissions:
  contents: write
  packages: write
  id-token: write
  checks: write
  actions: read
  attestations: write

jobs:
  release:
    name: ${{ (inputs.dry_run != false) && 'Release --dry-run' || 'Release' }}
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v6
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          persist-credentials: true

      - name: Setup workflow runtime environment
        id: workflow-runtime
        uses: savvy-web/workflow-runtime-action@main

      - name: Run release action
        uses: savvy-web/workflow-release-action@main
        with:
          app-id: ${{ secrets.APP_ID }}
          private-key: ${{ secrets.APP_PRIVATE_KEY }}
          github-token: ${{ secrets.GITHUB_TOKEN }}
          anthropic-api-key: ${{ secrets.ANTHROPIC_API_KEY }}
          claude-review-pat: ${{ secrets.CLAUDE_REVIEW_PAT }}
          dry-run: ${{ inputs.dry_run || 'false' }}
          custom-registries: |
            https://registry.savvyweb.dev/${{ secrets.SAVVYWEB_NPM_AUTH_TOKEN }}
