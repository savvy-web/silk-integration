{
	"name": "@savvy-web/workflow-integration",
	"version": "0.0.0",
	"private": true,
	"description": "A private repository for GitHub-related tools and utilities.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/workflow-integration.git"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped",
		"build:dev": "turbo run build:dev --log-order=grouped",
		"build:prod": "turbo run build:prod --log-order=grouped",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full",
		"ci:test": "CI=\"true\" turbo run //#vitest:all --log-prefix=none --log-order=grouped",
		"ci:version": "savvy-changesets version && biome format --write .",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"lint:tsdoc": "eslint --config ./lib/configs/eslint.config.ts --ignore-pattern '**/*.test.ts'",
		"prepare": "husky",
		"test": "turbo run vitest:all --log-prefix=none --log-order=grouped",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit",
		"vitest:all": "vitest --run"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.3.0",
		"@savvy-web/commitlint": "^0.3.4",
		"@savvy-web/lint-staged": "^0.4.6",
		"@savvy-web/vitest": "^0.1.0"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.30.3",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	}
}
